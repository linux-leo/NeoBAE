BAE_BUILT_IN_PATCHES	:= 1
BITS := 32
BAE_API			:= SDL2
BUILD_GUI   	:= 1
WINDOWS 		:= 0
XPHACK := 1
NOAUTO := 1
ENABLE_MIDI_HW	:= 1
PLAYLIST := 0
MP3_DEC := 1
MP3_ENC := 1
FLAC_DEC := 1
FLAC_ENC := 1
OGG_SUPPORT := 1
BAESCRIPT := 1
VORBIS_DEC := 1
VORBIS_ENC := 1
OPUS_DEC := 1
KARAOKE := 1
SF2_SUPPORT := 1
USE_FLUIDSYNTH := 1
EMBED_PATCHES := 1
EMBED_FONT := 1
XMF_SUPPORT := 1
DISABLE_NOKIA := 0
DISABLE_BEATNIK_SF2_NRPN := 0

include inc/Makefile.common

TARGET_BIN		:= $(TARGET_NAME).exe
SOURCE_DIR = $(CURDIR)

CROSS 		:= i686-w64-mingw32
ARCH		:= -static
CC			:= $(CROSS)-gcc
CXX			:= $(CROSS)-g++
# Use C++ linker if we have any C++ sources
ifneq ($(filter %.cpp,$(SRC) $(SRC_BIN)),)
LD			:= $(CXX)
else
LD			:= $(CC)
endif
AR      	:= $(CROSS)-gcc-ar
STRIP      	:= $(CROSS)-strip
DLLTOOL		:= $(CROSS)-dlltool
WINDRES		:= $(CROSS)-windres

OPTI            := -O2 -fPIC -march=pentium-mmx -mmmx -mno-sse -mno-sse2 -mno-sse3 -mno-sse4 -mno-sse4a -mno-3dnow -mno-avx -mno-avx2 -mfpmath=387 -fno-tree-vectorize
ifeq ($(LDEBUG),1)
    OPTI := -g -O0 -ggdb3 -fPIC -march=pentium-mmx -mmmx -mno-sse -mno-sse2 -mno-sse3 -mno-sse4 -mno-sse4a -mno-3dnow -mno-avx -mno-avx2 -mfpmath=387 -fno-tree-vectorize
endif
CFLAGS  	:= $(ARCH) $(OPTI) $(INC_PATH) -D_THREAD_SAFE -DEMBED_FONT_TTF -Wno-unused-value -DWINVER=0x0501 -D_WIN32_WINNT=0x0501



ifneq ($(ENABLE_MIDI_HW),)
	# WinMM MIDI HW Support
	CFLAGS += -D__WINDOWS_MM__ 
endif

ifneq ($(BAE_FLAGS),)
	CFLAGS	+= $(BAE_FLAGS)
endif

include inc/Makefile.versioning
CFLAGS		+= -D_VERSION=\""$(VERSION)"\"
CXXFLAGS 	:= $(CFLAGS)
LDFLAGS		:= $(ARCH) $(OPTI)


ifneq ($(BAE_LD_FLAGS),)
	LDFLAGS += $(BAE_LD_FLAGS)
endif

ifneq ($(LDEBUG),1)
	LDFLAGS += -s
endif

LIBS = \
	-lmingw32 \
	-lSDL2main \
	-lSDL2_ttf.dll \
	-lSDL2.dll \
	-lwinmm \
	-lole32 \
	-lcomdlg32 \
	-lfluidsynth-3.dll \
	-lfreetype.dll \
	-lbz2 \
	-lbrotlidec.dll \
	-lpng \
	-lpsapi

ifneq ($(BAE_LIBS),)
	LIBS += $(BAE_LIBS)
endif	

all: $(TARGET_LIB).a ${TARGET_LIB}.dll $(TARGET_BIN) $(TARGET_OUT)RegisterFiletypes.exe

$(OBJ_DIR)winreg_filetypes.o:
	$(CC) $(CFLAGS) -DUNICODE -D_UNICODE -c src/gui/winreg_filetypes.c -o $(OBJ_DIR)winreg_filetypes.o

$(TARGET_OUT)RegisterFiletypes.exe: $(OBJ_DIR)winreg_filetypes.o
	@mkdir -p $(TARGET_OUT)
	${WINDRES} src/gui/winreg_filetypes.rc $(OBJ_DIR)winreg_filetypes_res.o; \
	${LD} -o $(TARGET_OUT)RegisterFiletypes.exe ${LDFLAGS} $(OBJ_DIR)winreg_filetypes.o $(OBJ_DIR)winreg_filetypes_res.o -Wl,--subsystem,windows -lshlwapi -lgdi32 -lcomctl32

$(TARGET_LIB).a: $(OBJ)
	@mkdir -p $(TARGET_OUT)
	$(AR) rcs $(TARGET_OUT)$(TARGET_LIB).a $(OBJ)

$(TARGET_LIB).dll: ${OBJ}
	@mkdir -p $(TARGET_OUT)
	@$(DLLTOOL) --export-all --export-all-symbols -e $(OBJ_DIR)exports.o -z $(OBJ_DIR)$(TARGET_LIB).def2 $(OBJ)
	@echo "EXPORTS" > $(OBJ_DIR)$(TARGET_LIB).def
	@cat $(OBJ_DIR)$(TARGET_LIB).def2 | grep "BAE" >> $(OBJ_DIR)$(TARGET_LIB).def
	@rm -f $(OBJ_DIR)$(TARGET_LIB).def2 $(OBJ_DIR)exports.o
	@$(DLLTOOL) -e $(OBJ_DIR)exports.o -d $(OBJ_DIR)$(TARGET_LIB).def -l $(TARGET_OUT)$(TARGET_LIB).lib $(OBJ)
	$(CC) -shared $(LDFLAGS) ${OBJ} $(OBJ_DIR)exports.o -Wl,--subsystem,windows -o $(TARGET_OUT)${TARGET_LIB}.dll -Wl,--out-implib,$(TARGET_OUT)$(TARGET_LIB).dll.a -Wl,--export-all-symbols -Wl,--enable-auto-image-base -lstdc++ ${LIBS}

	@find /opt/mingw32-xp -name libgcc_s_dw2-1.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true;
	@find /opt/mingw32-xp -name libwinpthread-1.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true;
	@find /opt/mingw32-xp -name libstdc++-6.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true;
	@find /opt/mingw32-xp -name libgomp-1.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true;
	@find /opt/mingw32-xp -name libreadline8.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true;
	@find /opt/mingw32-xp -name libssp-0.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true;

	@if [ "$(USE_FLUIDSYNTH)" = "1" ]; then \
		find /opt/mingw32-xp -name libfluidsynth-3.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name libsndfile.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name libmp3lame-0.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name libbz2.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name libmpg123-0.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name libharfbuzz-0.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name libpng16.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name zlib1.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
	fi
	
	@if [ "$(OGG_SUPPORT)" = "1" ]; then \
		find /opt/mingw32-xp -name libogg.dll -exec cp {} $(TARGET_OUT)/ogg.dll \; 2>/dev/null || true; \
		\
		if [ "$(FLAC_DEC)" = "1" ] || [ "$(FLAC_ENC)" = "1" ]; then \
			find /opt/mingw32-xp -name libFLAC.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		fi; \
		\
		if [ "$(VORBIS_ENC)" = "1" ] || [ "$(VORBIS_DEC)" = "1" ]; then \
			find /opt/mingw32-xp -name libvorbis.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
			find /opt/mingw32-xp -name libvorbisfile.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		fi; \
		\
		if [ "$(VORBIS_ENC)" = "1" ]; then \
			find /opt/mingw32-xp -name libvorbisenc.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		fi; \
		\
		if [ "$(OPUS_DEC)" = "1" ]; then \
			find /opt/mingw32-xp -name libopus.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
			find /opt/mingw32-xp -name libopusfile-0.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		fi; \
	fi

	@if [ "$(BAE_API)" = "SDL2" ]; then \
		find /opt/mingw32-xp -name SDL2.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name SDL2_ttf.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name libfreetype.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
		find /opt/mingw32-xp -name libpng16-16.dll -exec cp {} $(TARGET_OUT) \; 2>/dev/null || true; \
	fi	

$(TARGET_BIN): ${OBJ_BIN} $(TARGET_LIB).dll
	@mkdir -p $(TARGET_OUT)Banks
	$(SHELL) src/banks/copy.sh $(TARGET_OUT)Banks
	${WINDRES} src/gui/zefidi.rc $(OBJ_DIR)zefidi.o; \
	${LD} -o $(TARGET_OUT)${TARGET_BIN} ${LDFLAGS} ${OBJ_BIN} $(OBJ_DIR)zefidi.o -Wl,--subsystem,windows -L./bin -lNeoBAE ${LIBS}; \

# Rules for compiling source files to object files
$(OBJ_DIR)%.o : %.cpp
	@echo @compile $<
	@mkdir -p $(OBJ_DIR)
	$(SILENT)${CXX} -c ${CXXFLAGS} $< -o $@

$(OBJ_DIR)%.o : %.c
	@echo @compile $<
	@mkdir -p $(OBJ_DIR)
	$(SILENT)${CC} -c ${CFLAGS} $< -o $@

clean:
	@rm -rf $(TARGET_OUT)
	@rm -rf $(OBJ_DIR)
	@rm -rf $(BUILD_DIR)
	@rm -rf $(TEST_OUT_DIR)
	@echo Cleaned!

# Generate rules for all unique source files (same approach as top-level Makefile)
ALL_SOURCES := $(sort $(SRC) $(SRC_BIN))
$(foreach src,$(ALL_SOURCES),$(eval $(call make_obj_rule,$(src))))

include inc/Makefile.tests
