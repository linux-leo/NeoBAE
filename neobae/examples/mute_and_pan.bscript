// Example BAEScript: Mute the drum channel (10) after 5 seconds,
// and pan channel 1 hard-left gradually based on time.

// Mute drums after 5 seconds
if (midi.timestamp >= 5000 && ch[10].mute == 0) {
    ch[10].mute = 1;
    print("Muted drums at", midi.timestamp, "ms");
}

// Gradually pan channel 1 from center (64) to hard-left (0)
// over the first 10 seconds of playback
if (midi.timestamp < 10000) {
    var panValue = 64 - (midi.timestamp * 64 / 10000);
    ch[1].pan = panValue;
}
