<?xml version="1.0" encoding="utf-8"?>
<!--
  nbstudio.props - User-configurable paths for the nbstudio Visual Studio project.

  REQUIRED: Set the following environment variables (or edit this file directly)
  before opening the solution:

    WXWIN    = Path to wxWidgets root (e.g. C:\wxWidgets-3.2.8)
               Build wxWidgets from source with MSVC first:
                 cd %WXWIN%\build\msw
                 nmake /f makefile.vc BUILD=release SHARED=0 TARGET_CPU=X64
                 nmake /f makefile.vc BUILD=debug   SHARED=0 TARGET_CPU=X64

    SDL3_DIR = Path to SDL3 development package root
               (e.g. C:\SDL3-devel-3.x.x-VC, extract from libsdl.org)

  OPTIONAL (only if FLAC/Vorbis/OGG system libs are NOT available):
    FLAC_DIR    = Path to libFLAC static build (needs FLAC.lib / libFLAC.lib)
    VORBIS_DIR  = Path to libvorbis static build (needs ogg.lib, vorbis.lib,
                  vorbisfile.lib, vorbisenc.lib)
    OGG_DIR     = Path to libogg static build

  NOTE: LAME (mp3lame) is built from the bundled source in
        src/thirdparty/lame-3.100-slim — no external library needed.

  NOTE: BAEPatches.h is generated by a pre-build event using Python.
        Ensure Python 3 is on your PATH, or generate it manually:
          python ..\..\scripts\create_embedded_patches_h.py ^
                 ..\src\banks\patches111\patches111.hsb ^
                 generated\BAEPatches.h
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- ================================================================
       wxWidgets paths — edit WXWIN here if not set as env variable
       ================================================================ -->
  <PropertyGroup>
    <WxWin Condition="'$(WXWIN)' != ''">$(WXWIN)</WxWin>
    <WxWin Condition="'$(WxWin)' == ''">D:\dev\wxWidgets-3.3.2-dev</WxWin>

    <FlacDir Condition="'$(FLAC_DIR)' != ''">$(FLAC_DIR)</FlacDir>
    <FlacDir Condition="'$(FlacDir)' == ''">$(ProjectDir)..\src\thirdparty\flac</FlacDir>

    <VorbisDir Condition="'$(VORBIS_DIR)' != ''">$(VORBIS_DIR)</VorbisDir>
    <OggDir Condition="'$(OGG_DIR)' != ''">$(OGG_DIR)</OggDir>
  </PropertyGroup>

  <!-- wxWidgets include paths (both common and MSVC-specific setup.h) -->
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>
        D:\dev\wxWidgets-3.3.2-src\include;
        $(WxWin)\lib\vc14x_x64_dll\mswu;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <AdditionalLibraryDirectories>
        $(WxWin)\lib\vc14x_x64_dll;
        %(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>

  <!-- Debug-specific wxWidgets lib path (mswud) -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <AdditionalIncludeDirectories>
        $(WxWin)\lib\vc14x_x64_dll\mswud;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>

  <!-- Optional external FLAC/Vorbis/OGG lib dirs (if not using vcpkg/system) -->
  <ItemDefinitionGroup Condition="'$(FLAC_DIR)' != ''">
    <Link>
      <AdditionalLibraryDirectories>$(FlacDir)\lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(VORBIS_DIR)' != ''">
    <Link>
      <AdditionalLibraryDirectories>$(VorbisDir)\lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(OGG_DIR)' != ''">
    <Link>
      <AdditionalLibraryDirectories>$(OggDir)\lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
  </ItemDefinitionGroup>

</Project>
